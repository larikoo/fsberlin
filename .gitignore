# Rust
target/
# Cargo.lock IS committed: the workspace ships a binary (berlin), so the
# lockfile is tracked for reproducible builds.

# Python
__pycache__/
*.py[cod]
.venv/
dist/
*.egg-info/

# Editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Local
.env
.env.local

# legion-provision: a separate, local-only homelab project (its own git repo,
# never published to this public remote). Kept out of fsberlin entirely.
legion-provision/

# FSBerlin local cache (regenerable from filesystem)
.fsberlin/index.sqlite
.fsberlin/index.sqlite-journal

# Beads / Dolt files (added by bd init) — bd data kept local, not published
.beads/
.dolt/
*.db
.beads-credential-key
